# ===== ai-plan-service config =====
# Single source of truth for local dev. Copy this to `.env` and edit.

AI_PLAN_HOST=0.0.0.0
AI_PLAN_PORT=8092

# ----- Downstream services (server-to-server, bypass gateway) -----
CATALOG_SERVICE_BASE_URL=http://localhost:8083
PLAN_SERVICE_BASE_URL=http://localhost:8086

# ----- JWT (used to extract user_id for traceability) -----
# Leave empty in dev — token has already been validated upstream.
JWT_SECRET=
JWT_ALGORITHM=HS256

# ----- LLM (any OpenAI-compatible provider) -----
# Leave LLM_API_KEY empty to run in offline stub mode (regex extractor, no agent loop).
#
# Examples:
#
#   OpenRouter (free + paid, single endpoint for many providers):
#     LLM_BASE_URL=https://openrouter.ai/api/v1
#     LLM_MODEL=google/gemini-2.0-flash-exp:free
#     LLM_API_KEY=sk-or-v1-...
#
#   OpenAI direct:
#     LLM_BASE_URL=https://api.openai.com/v1
#     LLM_MODEL=gpt-4o-mini
#     LLM_API_KEY=sk-...
#
#   Groq (free tier, fast):
#     LLM_BASE_URL=https://api.groq.com/openai/v1
#     LLM_MODEL=llama-3.3-70b-versatile
#     LLM_API_KEY=gsk_...
#
#   Local Ollama (no key needed, any value works):
#     LLM_BASE_URL=http://localhost:11434/v1
#     LLM_MODEL=llama3.1
#     LLM_API_KEY=ollama

LLM_API_KEY=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
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-2.0-flash-exp:free

# Optional: model used specifically for the cheap constraint-extraction call.
# Defaults to LLM_MODEL when empty.
LLM_EXTRACTOR_MODEL=

# Optional: identify your app to OpenRouter (shown on their dashboard)
LLM_APP_NAME=Mravel AI Plan Agent
LLM_APP_URL=

# ----- CORS for frontend dev server -----
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# ----- Web search fallback (prices / venues missing from the catalog) -----
# Provider: tavily. Empty key = disabled (agent falls back to heuristic pricing).
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_API_KEY=

# ----- Public web app origin (for clickable catalog links in chat) -----
# Leave EMPTY to emit relative links like /hotels/<slug>; the browser resolves
# them against the SPA origin, so they open the right Mravel detail page in-app.
# Set an absolute origin (e.g. https://mravel.vn) only if links are consumed
# outside the SPA.
PUBLIC_WEB_BASE_URL=

# ----- Session storage -----
# Backend: mongo (recommended) | file (legacy single JSON) | memory (no persistence).
SESSION_STORE_BACKEND=mongo
# Use the SAME MongoDB the app uses. The project runs on MongoDB Atlas and the catalog
# DB is `mravel_catalog` (see catalog-service application.yml for the real connection
# string). Put the real URI (it has credentials) in your local .env, NOT in git.
#   Atlas:  MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
#   Local:  MONGO_URI=mongodb://localhost:27017
MONGO_URI=mongodb://localhost:27017
MONGO_DB=mravel_catalog
SESSION_COLLECTION=ai_plan_sessions
# Import sessions from the legacy file on first start (true). Set false to start clean.
SESSION_MIGRATE_FROM_FILE=false
# Legacy "file" backend path + migration source. Empty = in-memory only.
SESSION_STORE_PATH=.data/sessions.json
